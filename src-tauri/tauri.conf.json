{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KH3 Ultrawide Patcher",
  "version": "1.0.0",
  "identifier": "io.github.lordblacksun.kh3uwpatcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "KH3 Ultrawide Patcher",
        "width": 760,
        "height": 820,
        "minWidth": 680,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "shortDescription": "Ultrawide patcher for KINGDOM HEARTS III",
    "longDescription": "Patches KINGDOM HEARTS III (Steam & Epic) to render true ultrawide (Hor+), with automatic install detection, backup, and one-click revert.",
    "license": "GPL-3.0-only",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
